# llmsdk-openai smoke 示例所需的环境变量。
# 复制为 .env 后填写你的真实值即可：
#   cp .env.example .env
# 程序加载顺序（先到先得）：
#   1. 真实进程环境变量（最高优先级）
#   2. $CWD/.env                                    （通常是仓库根）
#   3. crates/llmsdk-openai/.env                    （crate 内覆盖）
#   4. crates/llmsdk-openai/examples/.env           （example 同目录）

# ────────── 必填 ──────────
OPENAI_API_KEY=sk-your-key-here

# ────────── 可选：endpoint / 租户 ──────────
# 自建网关 / Azure / 代理：
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORG=org-xxxxxxxx
# OPENAI_PROJECT=proj_xxxxxxxx

# ────────── 可选：覆盖各 demo 默认模型 ──────────
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_REASONING_MODEL=o3-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_RESPONSES_MODEL=gpt-4o-mini

# ────────── 可选：vision / image demo 输入输出 ──────────
# OPENAI_VISION_IMAGE_URL=https://upload.wikimedia.org/wikipedia/commons/thumb/8/89/Tomato_je.jpg/320px-Tomato_je.jpg
# OPENAI_IMAGE_OUTPUT_PATH=/tmp/llmsdk_openai_demo.png
