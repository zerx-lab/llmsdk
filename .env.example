# llmsdk smoke 示例（openai / anthropic）所需的环境变量。
# 复制为 .env 后填写你的真实值即可：
#   cp .env.example .env
# 程序加载顺序（先到先得）：
#   1. 真实进程环境变量（最高优先级）
#   2. $CWD/.env                                    （通常是仓库根）
#   3. crates/<provider>/.env                       （crate 内覆盖）
#   4. crates/<provider>/examples/.env              （example 同目录）

# ══════════════════════════════════════════════════════════════════
# OpenAI (cargo run -p llmsdk-openai --example openai_smoke)
# ══════════════════════════════════════════════════════════════════

# ────────── 必填 ──────────
OPENAI_API_KEY=sk-your-key-here

# ────────── 可选：endpoint / 租户 ──────────
# 自建网关 / Azure / 代理：
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORG=org-xxxxxxxx
# OPENAI_PROJECT=proj_xxxxxxxx

# ────────── 可选：覆盖各 demo 默认模型 ──────────
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_REASONING_MODEL=o3-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_RESPONSES_MODEL=gpt-4o-mini

# ────────── 可选：vision / image demo 输入输出 ──────────
# OPENAI_VISION_IMAGE_URL=https://upload.wikimedia.org/wikipedia/commons/thumb/8/89/Tomato_je.jpg/320px-Tomato_je.jpg
# OPENAI_IMAGE_OUTPUT_PATH=/tmp/llmsdk_openai_demo.png

# ══════════════════════════════════════════════════════════════════
# Anthropic (cargo run -p llmsdk-anthropic --example anthropic_smoke)
# ══════════════════════════════════════════════════════════════════

# ────────── 必填：二选一 ──────────
# 标准 API key：
ANTHROPIC_API_KEY=sk-ant-your-key-here
# 或 OAuth bearer token（与 ANTHROPIC_API_KEY 互斥）：
# ANTHROPIC_AUTH_TOKEN=your-oauth-token

# ────────── 可选：endpoint / 版本 ──────────
# 自建网关 / 代理：
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_VERSION=2023-06-01

# ────────── 可选：覆盖各 demo 默认模型 ──────────
# ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_THINKING_MODEL=claude-3-7-sonnet-latest
# ANTHROPIC_WEB_SEARCH_MODEL=claude-3-5-sonnet-latest

# ────────── 可选：vision demo 输入图片 ──────────
# ANTHROPIC_VISION_IMAGE_URL=https://upload.wikimedia.org/wikipedia/commons/thumb/8/89/Tomato_je.jpg/320px-Tomato_je.jpg
